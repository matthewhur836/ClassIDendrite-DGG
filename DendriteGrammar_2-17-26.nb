                    ",", "tenmgradientMean", ",", "tenmgradientStd", ",", 
                   RowBox[{"Clip", "[", 
                    RowBox[{
                    RowBox[{"t", "-", 
                    RowBox[{"(", 
                    RowBox[{"secondaryGrowthTime", "-", "ramp"}], ")"}]}], ",", 
                    RowBox[{"{", 
                    RowBox[{"0.01", ",", "ramp"}], "}"}]}], "]"}], ",", 
                   "0."}], "]"}], ",", "\[Theta]", ",", "\[Sigma]", ",", 
                 "baselineGrowth"}], "]"}]}], "/.", 
              RowBox[{"Join", "[", "fitGrowthTenm", "]"}]}], ")"}], "*", 
            "20."}], "-", "10."}], ",", 
          RowBox[{"{", 
