 RowBox[{
  RowBox[{
   RowBox[{"animateGrowth", "[", 
    RowBox[{"simulationArray_", ",", 
     RowBox[{"gradient_", ":", "False"}]}], "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "graphics", ",", "gradientPlotTenm", ",", "gradientPlotWnt", ",", 
       "gradientPlotEmpty", ",", "colorGradient", ",", "treeframes", ",", 
       "derivGradientRight"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"(*", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"derivGradientRight", "[", 
         RowBox[{
          RowBox[{"coords_", "?", "VectorQ"}], ",", 
          RowBox[{"mean_", "?", "VectorQ"}], ",", 
          RowBox[{"std_", "?", "VectorQ"}], ",", 
          RowBox[{"taccum_", "?", "NumericQ"}], ",", 
          RowBox[{"tdecay_", "?", "NumericQ"}]}], "]"}], ":=", 
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"diff", ",", "invCov", ",", "base"}], "}"}], ",", 
          RowBox[{
           RowBox[{"diff", "=", 
            RowBox[{
             RowBox[{"coords", "[", 
              RowBox[{"[", 
               RowBox[{";;", 
                RowBox[{"Length", "[", "mean", "]"}]}], "]"}], "]"}], "-", 
             "mean"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"invCov", "=", 
            RowBox[{"DiagonalMatrix", "[", 
             RowBox[{"1", "/", 
              RowBox[{"std", "^", "2"}]}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"base", "=", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"taccum", "*", "\[Lambda]accum"}], ")"}], "*", 
             RowBox[{
              RowBox[{"Exp", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{"-", "1"}], "/", "2"}], " ", 
                 RowBox[{"diff", ".", "invCov", ".", "diff"}]}], "-", 
                RowBox[{"tdecay", "*", "\[Lambda]decay"}]}], "]"}], "/", 
              RowBox[{"Sqrt", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"2", " ", "Pi"}], ")"}], "^", 
                 RowBox[{"Length", "[", "mean", "]"}]}], " ", 
                RowBox[{"Times", "@@", 
                 RowBox[{"(", 
                  RowBox[{"1.", "/", 
                   RowBox[{"std", "^", "2"}]}], ")"}]}]}], "]"}]}]}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", 
               RowBox[{"invCov", ".", "diff"}]}], "*", "base"}], ")"}], "[", 
            RowBox[{"[", "1", "]"}], "]"}]}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"gradientPlotTenm", "[", "t_", "]"}], ":=", 
        RowBox[{"Plot", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"\[Sigma]", "-", 
               RowBox[{"hill", "[", 
                RowBox[{
                 RowBox[{"GradientNorm", "[", 
